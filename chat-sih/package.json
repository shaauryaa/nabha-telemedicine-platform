{
  "name": "chat-sih-community",
  "version": "1.0.0",
  "description": "Real-time community chat and forum system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
